{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
  "target": "ES2021",

    "outDir": "./dist",
    "sourceMap": true,
    "incremental": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "baseUrl": "./",
    "paths": {
      "@modules/*": ["src/*"]
    },

    "strict": true,
    "skipLibCheck": true
  }
}
